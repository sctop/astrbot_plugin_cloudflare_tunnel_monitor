{
  "api_token": {
    "description": "CloudFlare API Token",
    "hint": "详见 https://developers.cloudflare.com/fundamentals/api/get-started/create-token/",
    "type": "string"
  },
  "account_id": {
    "description": "CloudFlare Account ID",
    "hint": "详见 https://developers.cloudflare.com/fundamentals/account/find-account-and-zone-ids/",
    "type": "string"
  },
  "time_timezone": {
    "description": "输出时间时所用时区",
    "hint": "默认为 Asia/Taipei 以规避（现在虽然遇不到但为了方便还是这么写了）历史夏令时问题",
    "type": "string",
    "default": "Asia/Taipei"
  },
  "polling_time": {
    "description": "轮询的等待时间",
    "hint": "以秒计，越短间隔越能精确报告问题出现时间点",
    "type": "int",
    "default": 20
  },
  "http_proxy": {
    "description": "代理服务器",
    "hint": "访问 CloudFlare API 时使用的代理服务器 (HTTP/HTTPS, via httpx lib)",
    "type": "string"
  }
}